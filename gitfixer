#!/usr/bin/env bash
set -euo pipefail

REPO_URL="https://github.com/j-p-tome/IAMinistrator.git"
DEFAULT_BRANCH="main"

log() {
  printf '[*] %s\n' "$*"
}

warn() {
  printf '[!] %s\n' "$*" >&2
}

die() {
  printf '[x] %s\n' "$*" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

need_cmd git

if [ ! -d . ]; then
  die "Current directory is not accessible."
fi

if [ ! -f Cargo.toml ]; then
  warn "Cargo.toml not found in $(pwd). Make sure you're in your IAMinistrator project root."
fi

log "Repository root: $(pwd)"

if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  log "Git repository detected."
else
  log "Initializing git repository..."
  git init
fi

CURRENT_NAME="$(git config user.name || true)"
CURRENT_EMAIL="$(git config user.email || true)"
GLOBAL_NAME="$(git config --global user.name || true)"
GLOBAL_EMAIL="$(git config --global user.email || true)"

if [ -z "$CURRENT_NAME" ] || [ -z "$CURRENT_EMAIL" ]; then
  warn "Local git identity is incomplete for this repo."
  if [ -n "$GLOBAL_NAME" ] && [ -n "$GLOBAL_EMAIL" ]; then
    log "Using existing global git identity: $GLOBAL_NAME <$GLOBAL_EMAIL>"
    git config user.name "$GLOBAL_NAME"
    git config user.email "$GLOBAL_EMAIL"
  else
    printf 'Git author name: '
    read -r INPUT_NAME
    printf 'Git author email: '
    read -r INPUT_EMAIL

    [ -n "$INPUT_NAME" ] || die "Git author name cannot be empty."
    [ -n "$INPUT_EMAIL" ] || die "Git author email cannot be empty."

    git config user.name "$INPUT_NAME"
    git config user.email "$INPUT_EMAIL"

    printf 'Also save these globally to ~/.gitconfig? [y/N]: '
    read -r SAVE_GLOBAL
    case "${SAVE_GLOBAL:-N}" in
      y|Y|yes|YES)
        git config --global user.name "$INPUT_NAME"
        git config --global user.email "$INPUT_EMAIL"
        log "Saved global git identity."
        ;;
      *)
        log "Saved identity locally to this repository only."
        ;;
    esac
  fi
fi

log "Effective git identity: $(git config user.name) <$(git config user.email)>"
log "Identity source check:"
git config --show-origin --get user.name || true
git config --show-origin --get user.email || true

if ! git diff --cached --quiet 2>/dev/null || ! git diff --quiet 2>/dev/null || [ -n "$(git ls-files --others --exclude-standard)" ]; then
  log "Staging files..."
  git add .
else
  log "No unstaged changes detected."
fi

if git rev-parse --verify HEAD >/dev/null 2>&1; then
  log "A commit already exists. Skipping initial commit creation."
else
  log "Creating initial commit..."
  git commit -m "Initial IAMinistrator scaffold"
fi

CURRENT_BRANCH="$(git branch --show-current || true)"
if [ "$CURRENT_BRANCH" != "$DEFAULT_BRANCH" ]; then
  log "Setting branch to $DEFAULT_BRANCH"
  git branch -M "$DEFAULT_BRANCH"
fi

if git remote get-url origin >/dev/null 2>&1; then
  EXISTING_REMOTE="$(git remote get-url origin)"
  if [ "$EXISTING_REMOTE" != "$REPO_URL" ]; then
    warn "Remote origin exists but points to: $EXISTING_REMOTE"
    printf 'Replace origin with %s ? [y/N]: ' "$REPO_URL"
    read -r REPLACE_REMOTE
    case "${REPLACE_REMOTE:-N}" in
      y|Y|yes|YES)
        git remote set-url origin "$REPO_URL"
        log "Updated origin remote."
        ;;
      *)
        die "Leaving existing origin unchanged."
        ;;
    esac
  else
    log "Origin remote already set correctly."
  fi
else
  log "Adding origin remote..."
  git remote add origin "$REPO_URL"
fi

if command -v gh >/dev/null 2>&1; then
  if gh auth status >/dev/null 2>&1; then
    log "GitHub CLI is authenticated."
  else
    warn "gh is installed but not authenticated."
    warn "On NixOS, a common path is to run: nix shell nixpkgs#gh -c gh auth login"
    printf 'Run gh auth login now? [y/N]: '
    read -r RUN_GH_LOGIN
    case "${RUN_GH_LOGIN:-N}" in
      y|Y|yes|YES)
        gh auth login
        ;;
      *)
        warn "Continuing without gh login. git push may still work if your credentials helper is configured."
        ;;
    esac
  fi
else
  warn "gh is not installed. On NixOS you can use one of these:"
  warn "  nix shell nixpkgs#gh -c gh auth login"
  warn "  nix profile install nixpkgs#gh"
  warn "GitHub no longer supports account passwords for HTTPS git pushes; use gh auth login or a PAT."
fi

log "Pushing to $REPO_URL ..."
if git push -u origin "$DEFAULT_BRANCH"; then
  log "Push successful."
  log "Repo: https://github.com/j-p-tome/IAMinistrator"
else
  warn "git push failed. Common fixes on NixOS/Linux:"
  warn "  1. Authenticate with GitHub CLI: gh auth login"
  warn "  2. Or use a Personal Access Token for HTTPS auth"
  warn "  3. Verify credentials helper setup if using HTTPS"
  exit 1
fi

